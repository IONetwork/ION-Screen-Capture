{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ION Screen Capture",
  "version": "0.3.1",
  "identifier": "ion.screencapture",
  "build": {
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ION Screen Capture",
        "width": 1040,
        "height": 720,
        "minWidth": 760,
        "minHeight": 540,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "ION",
    "copyright": "Copyright © 2026 ION",
    "shortDescription": "Capture instrument screens over the network",
    "longDescription": "Discover SCPI/LXI instruments on the network and capture their screens (Rigol, Keysight, Siglent, Tektronix, and other screen-equipped instruments).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": [
          "English"
        ]
      }
    }
  }
}