{
  "name": "ion-screen-capture",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ION Screen Capture — capture screens from SCPI/LXI instruments over the network (Tauri + Svelte)",
  "scripts": {
    "dev": "vite --config svelte/vite.config.ts",
    "build": "vite build --config svelte/vite.config.ts",
    "preview": "vite preview --config svelte/vite.config.ts",
    "check": "svelte-check --workspace svelte --tsconfig ./tsconfig.app.json && tsc -p svelte/tsconfig.node.json",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-store": "^2",
    "bits-ui": "^2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.13.2",
    "esbuild": "^0.28.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
